{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coherence/section-index",
  "type": "object",
  "required": ["built_at", "entries"],
  "additionalProperties": false,
  "properties": {
    "built_at": { "type": "string", "format": "date-time" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sectionRef", "line_start", "line_end", "contentHash"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "sectionRef": { "type": "string" },
          "heading": { "type": "string" },
          "line_start": { "type": "integer", "minimum": 0 },
          "line_end": { "type": "integer", "minimum": 0 },
          "contentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
