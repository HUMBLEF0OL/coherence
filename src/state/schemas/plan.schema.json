{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coherence/plan",
  "type": "object",
  "required": ["canonical", "sections"],
  "additionalProperties": false,
  "properties": {
    "canonical": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sectionRef", "role"],
        "additionalProperties": false,
        "properties": {
          "sectionRef": { "type": "string" },
          "role": { "type": "string", "enum": ["canonical", "reference", "no-change"] },
          "relation": { "type": "string", "enum": ["owns", "mirrors", "omits"] }
        }
      }
    },
    "demoted_canonicals": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
