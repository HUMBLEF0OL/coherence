{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coherence/config",
  "type": "object",
  "required": ["mode"],
  "additionalProperties": false,
  "properties": {
    "mode": { "type": "string", "enum": ["observe", "graduated"] },
    "watches": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ignore": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
