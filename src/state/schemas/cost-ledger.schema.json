{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coherence/cost-ledger",
  "type": "object",
  "required": ["session_id", "entries"],
  "additionalProperties": false,
  "properties": {
    "session_id": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["session_id", "timestamp", "stage", "input_tokens", "output_tokens", "cost_usd", "prompt_version"],
        "additionalProperties": false,
        "properties": {
          "session_id": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "stage": { "type": "string", "enum": ["stage1", "stage2"] },
          "input_tokens": { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "cost_usd": { "type": "number", "minimum": 0 },
          "prompt_version": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "stage1": { "type": "string" },
              "stage2": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
