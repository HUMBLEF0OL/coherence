{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coherence/velocity",
  "type": "object",
  "required": ["revert_window_start", "revert_count", "revert_timestamps", "consecutive_defer_sessions", "auto_ignored"],
  "additionalProperties": false,
  "properties": {
    "revert_window_start": { "type": "string", "format": "date-time" },
    "revert_count": { "type": "integer", "minimum": 0 },
    "revert_timestamps": {
      "type": "array",
      "items": { "type": "string", "format": "date-time" }
    },
    "consecutive_defer_sessions": { "type": "integer", "minimum": 0 },
    "last_defer_session_id": { "type": "string" },
    "auto_ignored": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
