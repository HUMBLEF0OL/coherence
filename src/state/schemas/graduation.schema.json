{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coherence/graduation",
  "type": "object",
  "required": ["schema_version", "global_mode", "scopes"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 2 },
    "global_mode": { "type": "string", "enum": ["observe", "annotate", "author"] },
    "scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "mode"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "mode": { "type": "string", "enum": ["observe", "annotate", "author"] }
        }
      }
    },
    "de_annotate": {
      "type": "array",
      "description": "v0.3 M5: per-scope de-annotate decisions (DD-102/DD-110).",
      "items": {
        "type": "object",
        "required": ["path", "scope", "action", "recorded_at"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "scope": { "type": "string", "enum": ["per-doc", "per-directory", "global"] },
          "action": { "type": "string", "enum": ["strip", "keep-as-user-anchor"] },
          "recorded_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
