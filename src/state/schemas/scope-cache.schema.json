{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coherence/scope-cache",
  "type": "object",
  "required": ["schema_version", "generated_at", "entries"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 3 },
    "generated_at": { "type": "string", "format": "date-time" },
    "entries": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["file", "ancestor_chain", "extends_resolved", "written_at"],
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "ancestor_chain": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["file", "mtimeMs"],
              "additionalProperties": false,
              "properties": {
                "file": { "type": "string", "minLength": 1 },
                "mtimeMs": { "type": "number", "minimum": 0 }
              }
            }
          },
          "extends_resolved": { "type": "object" },
          "written_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
